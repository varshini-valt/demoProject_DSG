{
  "name": "wir",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node create-env.ts && ng serve -o",
    "build:dev": "cross-env NODE_ENV=dev node set.env.ts && ng build --configuration dev --base-href=/students/",
    "build:stage": "cross-env NODE_ENV=stage node set.env.ts && ng build --configuration stage --base-href=/students/",
    "build:uat": "cross-env NODE_ENV=uat node set.env.ts && ng build --configuration uat --base-href=/students/",
    "build:prod": "cross-env NODE_ENV=prod node set.env.ts && ng build --configuration prod --base-href=/students/",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint -f html -o ./reports/eslint-report.html --color --ext .ts src",
    "lint:fix": "eslint ./ --fix",
    "lint:dryrun": "eslint ./ --fix-dry-run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --colors"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^18.2.14",
    "@angular/material-moment-adapter": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@aws-amplify/auth": "^6.12.4",
    "aws-amplify": "^6.14.4",
    "crypto-js": "^4.2.0",
    "js-sha1": "^0.7.0",
    "moment": "^2.30.1",
    "ngx-cookie-service": "^16.1.0",
    "ngx-mat-select-search": "^8.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.3",
    "@typescript-eslint/eslint-plugin": "^5.43.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.42.0",
    "eslint-config-standard-with-typescript": "^23.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.5.1",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.6.1",
    "jest-preset-angular": "^13.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "~5.4.5"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/setupJest.ts"
    ],
    "moduleNameMapper": {
      "^crypto$": "crypto-js",
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  },
  "overrides": {
    "@angular-devkit/build-angular": {
      "webpack-dev-server": "^5.2.1"
    },
    "form-data": "^2.5.4",
    "tmp": "0.2.4"
  }
}
